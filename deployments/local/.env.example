# =============================================================================
# Local Development Stack — Environment Variables
# =============================================================================
# Copy ไฟล์นี้เป็น .env แล้วแก้ค่าตามต้องการ:
#   cp .env.example .env
# =============================================================================

# >> PostgreSQL
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_PORT=5432

# >> Redis
REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379

# >> Kafka (KRaft — no Zookeeper)
KAFKA_IMAGE=apache/kafka:3.9.0
KAFKA_PORT=29092

# >> Kafka UI
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:v0.7.2
KAFKA_UI_PORT=8080
