# =============================================================================
# Observability Stack — Environment Variables
# =============================================================================
# ใช้โดย docker-compose.yaml + otel-collector.yaml
# copy เป็น .env แล้วแก้ค่าตามต้องการ

# >> Image versions
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.120.0
TEMPO_IMAGE=grafana/tempo:2.7.2
PROMETHEUS_IMAGE=prom/prometheus:v3.2.1
GRAFANA_IMAGE=grafana/grafana:11.5.2

# >> Exposed ports (host → container)
OTEL_COLLECTOR_PORT=4318
TEMPO_PORT=3200
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# >> OTel Collector — batch processor
OTEL_BATCH_TIMEOUT=5s
OTEL_BATCH_SIZE=1024

# >> Go app target (สำหรับ Prometheus scrape)
APP_HOST=host.docker.internal
APP_PORT=3000
APP_METRICS_PATH=/metrics
APP_SCRAPE_INTERVAL=10s

# >> Grafana credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
