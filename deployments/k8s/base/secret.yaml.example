# ⚠️  TEMPLATE — Copy to secret.yaml before deploying
# Production: ใช้ External Secrets Operator หรือ Sealed Secrets แทน
#
# วิธีใช้:
#   cp secret.yaml.example secret.yaml
#   # แก้ค่าใน secret.yaml แล้ว apply
#   kubectl apply -f secret.yaml -n anc-portal
#
# หรือสร้างผ่าน kubectl โดยตรง:
#   kubectl create secret generic anc-portal-secret \
#     --from-literal=DB_USER=<user> \
#     --from-literal=DB_PASSWORD=<password> \
#     --from-literal=REDIS_PASSWORD=<password> \
#     --from-literal=JWT_SECRET_KEY=<secret> \
#     -n anc-portal
apiVersion: v1
kind: Secret
metadata:
  name: anc-portal-secret
  namespace: anc-portal
  labels:
    app.kubernetes.io/part-of: anc-portal
type: Opaque
stringData:
  DB_USER: "anc_app"
  DB_PASSWORD: "CHANGE_ME"
  REDIS_PASSWORD: ""
  JWT_SECRET_KEY: "CHANGE_ME"
