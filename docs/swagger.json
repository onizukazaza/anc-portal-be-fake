{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Backend API for ANC Insurance Portal",
        "title": "ANC Portal API",
        "contact": {},
        "version": "1.0.0"
    },
    "host": "localhost:20000",
    "basePath": "/v1",
    "paths": {
        "/auth/login": {
            "post": {
                "description": "Authenticate user with username and password, then return access token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Login user",
                "parameters": [
                    {
                        "description": "Login payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_modules_auth_adapters_http.loginRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Login success",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request body",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "401": {
                        "description": "Invalid credentials",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    }
                }
            }
        },
        "/cmi/{job_id}/request-policy-single-cmi": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "ดึงข้อมูลงาน พรบ. เดี่ยว (Compulsory Motor Insurance) ตาม job_id",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "CMI"
                ],
                "summary": "Get CMI policy by job ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Job ID",
                        "name": "job_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "CMI policy data",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "400": {
                        "description": "Job ID is required",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "404": {
                        "description": "Job not found",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    }
                }
            }
        },
        "/external-db/health": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Test connectivity of all registered external databases",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ExternalDB"
                ],
                "summary": "Check all external databases",
                "responses": {
                    "200": {
                        "description": "All database statuses",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    }
                }
            }
        },
        "/external-db/health/{name}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Test connectivity of a specific external database",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ExternalDB"
                ],
                "summary": "Check external database by name",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Database name",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Database status",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "400": {
                        "description": "Name is required",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "404": {
                        "description": "Database not found",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    }
                }
            }
        },
        "/quotations": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Retrieve paginated quotations for a given customer from external ERP database",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Quotation"
                ],
                "summary": "List quotations by customer",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Customer ID",
                        "name": "customerId",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "default": 1,
                        "description": "Page number",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 20,
                        "description": "Items per page",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "enum": [
                            "created_at",
                            "doc_no",
                            "total_amount",
                            "status"
                        ],
                        "type": "string",
                        "description": "Sort column",
                        "name": "sort",
                        "in": "query"
                    },
                    {
                        "enum": [
                            "asc",
                            "desc"
                        ],
                        "type": "string",
                        "default": "desc",
                        "description": "Sort order",
                        "name": "order",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated quotations",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "400": {
                        "description": "Customer ID is required",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    }
                }
            }
        },
        "/quotations/{id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Retrieve a single quotation from external ERP database",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Quotation"
                ],
                "summary": "Get quotation by ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Quotation ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Quotation data",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "404": {
                        "description": "Quotation not found",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "github_com_anc-portal_anc-portal-be_internal_shared_dto.ApiResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "description": "คำอธิบาย (\"success\", \"created successfully\", \"not found\")",
                    "type": "string"
                },
                "result": {
                    "description": "ข้อมูลผลลัพธ์ — null ถ้า error"
                },
                "status": {
                    "description": "\"OK\" หรือ \"ERROR\"",
                    "type": "string"
                },
                "status_code": {
                    "description": "HTTP status code (200, 201, 400, 500, ...)",
                    "type": "integer"
                }
            }
        },
        "internal_modules_auth_adapters_http.loginRequest": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string",
                    "example": "secret123"
                },
                "username": {
                    "type": "string",
                    "example": "admin"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Input: Bearer {access_token}",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}