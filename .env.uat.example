# =============================================================================
# UAT Environment Variables (copy to .env.uat)
# =============================================================================
#   cp .env.uat.example .env.uat
# =============================================================================

# ── App ──
STAGE_STATUS=staging
SERVER_PORT=20000
SERVER_BODY_LIMIT=10485760
SERVER_TIMEOUT=30s
SERVER_ALLOW_ORIGINS=https://uat-portal.anc.co.th
SERVER_JWT_SECRET_KEY=change-me-uat-jwt-secret

# ── API Keys ──
SERVER_APIKEYS_INTERNAL=change-me-uat-internal-key
SERVER_APIKEYS_PARTNER=change-me-uat-partner-key

# ── Rate Limit ──
SERVER_RATE_LIMIT_ENABLED=true
SERVER_RATE_LIMIT_MAX=200
SERVER_RATE_LIMIT_EXPIRATION=1m

# ── Database ──
DB_HOST=uat-db.anc.co.th
DB_PORT=5432
DB_USER=anc_uat_user
DB_PASSWORD=change-me-uat-db-password
DB_NAME=anc_portal_uat
DB_SSLMODE=require
DB_SCHEMA=public
DB_MAX_CONNS=20
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_CONNECT_TIMEOUT=10s
DB_STATEMENT_TIMEOUT=30s

# ── Redis ──
REDIS_ENABLED=true
REDIS_HOST=uat-redis.anc.co.th
REDIS_PORT=6379
REDIS_PASSWORD=change-me-uat-redis-password
REDIS_DB=0
REDIS_KEY_PREFIX=anc-uat:

# ── Local Cache ──
LOCAL_CACHE_ENABLED=true
LOCAL_CACHE_MAX_SIZE=10000
LOCAL_CACHE_TTL=5m

# ── Kafka ──
KAFKA_ENABLED=true
KAFKA_BROKERS=uat-kafka.anc.co.th:9092
KAFKA_TOPIC=anc-portal-events-uat
KAFKA_GROUP_ID=anc-portal-worker-uat
KAFKA_DLQ_TOPIC=anc-portal-events-uat-dlq
KAFKA_WRITE_TIMEOUT=10s
KAFKA_MAX_BYTES=10485760
KAFKA_MAX_RETRIES=3

# ── OTel ──
OTEL_ENABLED=true
OTEL_SERVICE_NAME=anc-portal-be
OTEL_ENV=uat
OTEL_SAMPLE_RATIO=0.5
OTEL_EXPORTER_URL=http://uat-otel-collector.anc.co.th:4318

# ── Swagger (enabled for UAT testing) ──
SWAGGER_ENABLED=true
SWAGGER_HOST=uat-portal-api.anc.co.th
SWAGGER_SCHEMES=https
SWAGGER_BASE_PATH=/v1
