# =============================================================================
# Production Environment Variables (copy to .env.prod)
# =============================================================================
#   cp .env.prod.example .env.prod
# =============================================================================

# ── App ──
STAGE_STATUS=production
SERVER_PORT=20000
SERVER_BODY_LIMIT=10485760
SERVER_TIMEOUT=30s
SERVER_ALLOW_ORIGINS=https://portal.anc.co.th
SERVER_JWT_SECRET_KEY=change-me-prod-jwt-secret

# ── API Keys ──
SERVER_APIKEYS_INTERNAL=change-me-prod-internal-key
SERVER_APIKEYS_PARTNER=change-me-prod-partner-key

# ── Rate Limit ──
SERVER_RATE_LIMIT_ENABLED=true
SERVER_RATE_LIMIT_MAX=100
SERVER_RATE_LIMIT_EXPIRATION=1m

# ── Database ──
DB_HOST=prod-db.anc.co.th
DB_PORT=5432
DB_USER=anc_prod_user
DB_PASSWORD=change-me-prod-db-password
DB_NAME=anc_portal
DB_SSLMODE=require
DB_SCHEMA=public
DB_MAX_CONNS=50
DB_MIN_CONNS=10
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_CONNECT_TIMEOUT=10s
DB_STATEMENT_TIMEOUT=30s

# ── Redis ──
REDIS_ENABLED=true
REDIS_HOST=prod-redis.anc.co.th
REDIS_PORT=6379
REDIS_PASSWORD=change-me-prod-redis-password
REDIS_DB=0
REDIS_KEY_PREFIX=anc:

# ── Local Cache ──
LOCAL_CACHE_ENABLED=true
LOCAL_CACHE_MAX_SIZE=20000
LOCAL_CACHE_TTL=5m

# ── Kafka ──
KAFKA_ENABLED=true
KAFKA_BROKERS=prod-kafka.anc.co.th:9092
KAFKA_TOPIC=anc-portal-events
KAFKA_GROUP_ID=anc-portal-worker
KAFKA_DLQ_TOPIC=anc-portal-events-dlq
KAFKA_WRITE_TIMEOUT=10s
KAFKA_MAX_BYTES=10485760
KAFKA_MAX_RETRIES=5

# ── OTel ──
OTEL_ENABLED=true
OTEL_SERVICE_NAME=anc-portal-be
OTEL_ENV=production
OTEL_SAMPLE_RATIO=0.1
OTEL_EXPORTER_URL=http://prod-otel-collector.anc.co.th:4318

# ── Swagger (disabled in production) ──
SWAGGER_ENABLED=false
