# =============================================================================
# Local Environment Variables (copy to .env.local)
# =============================================================================
# ไฟล์นี้เป็นตัวอย่าง — copy แล้วเปลี่ยน URL เป็นของจริง
#   cp .env.local.example .env.local
#
# Discord Webhook สำหรับ run.ps1 ci แจ้งผลไป channel
# สร้างได้ที่: Discord Channel → Edit → Integrations → Webhooks → New Webhook
# =============================================================================

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
